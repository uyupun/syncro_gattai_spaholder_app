#!/bin/sh
# Pre-commit hook for Flutter project
# This script runs dart format and dart analyze before each commit

echo "🪝 Running pre-commit checks..."

# Get list of staged Dart files
STAGED_DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.dart$')

if [ -n "$STAGED_DART_FILES" ]; then
    echo "🎨 Formatting Dart files..."
    
    # Format staged files
    dart format $STAGED_DART_FILES
    
    # Check if formatting changed anything
    if ! git diff --exit-code $STAGED_DART_FILES > /dev/null; then
        echo "✅ Files formatted. Adding changes to commit..."
        git add $STAGED_DART_FILES
    fi
fi

# Run dart analyze on staged files only
if [ -n "$STAGED_DART_FILES" ]; then
    echo "🔍 Running dart analyze on staged files..."
    if ! dart analyze --fatal-infos $STAGED_DART_FILES; then
        echo "❌ Dart analyze failed. Please fix the issues before committing."
        exit 1
    fi
else
    echo "ℹ️  No Dart files to analyze."
fi

echo "✅ All pre-commit checks passed!"
exit 0
